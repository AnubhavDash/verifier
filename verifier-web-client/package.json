{
  "name": "Verifier",
  "version": "1.0.2",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.config.json --base-href /",
    "build": "ng lint && ng build --prod",
    "lint": "ng lint",
    "electron": "electron .",
    "electron-build": "ng lint && ng build --prod && electron .",
    "electron-package": "ng lint && ng build --prod && electron-packager . --no-prune --ignore=/e2e --ignore=/src --overwrite --out=target --platform=win32 --arch=x64 --asar=true"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^8.2.14",
    "@angular/common": "^8.2.14",
    "@angular/compiler": "^8.2.14",
    "@angular/core": "^8.2.14",
    "@angular/forms": "^8.2.14",
    "@angular/platform-browser": "^8.2.14",
    "@angular/platform-browser-dynamic": "^8.2.14",
    "@angular/router": "^8.2.14",
    "bootstrap": "^4.5.3",
    "bootstrap-icons": "^1.3.0",
    "core-js": "^3.8.2",
    "jquery": "^3.5.0",
    "minimal-request-promise": "^1.5.0",
    "net": "^1.0.2",
    "rxjs": "^6.4.0",
    "sockjs-client": "^1.5.0",
    "stompjs": "^2.3.3",
    "@stomp/stompjs": "^6.0.0",
    "tree-kill": "^1.2.2",
    "tslib": "^1.14.1",
    "typescript": "~3.5.3",
    "zone.js": "^0.9.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^0.803.24",
    "@angular/cli": "^8.2.2",
    "@angular/compiler-cli": "^8.2.14",
    "@angular/language-service": "^8.2.14",
    "@types/jasmine": "~2.8.3",
    "@types/jasminewd2": "~2.0.2",
    "@types/node": "~6.0.60",
    "codelyzer": "^6.0.1",
    "electron": "11.2.0",
    "electron-packager": "^15.2.0",
    "tslint": "~5.9.1",
    "winston": "^3.3.3",
    "dateformat": "^4.4.1"
  }
}
