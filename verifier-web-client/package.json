{
  "name": "Verifier",
  "version": "0.0.0",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.config.json --base-href /",
    "build": "ng lint && ng build --prod",
    "lint": "ng lint",
    "electron": "electron .",
    "electron-build": "ng lint && ng build --prod && electron .",
    "electron-package": "ng lint && ng build --prod && electron-packager . --no-prune --ignore=/e2e --ignore=/src --overwrite --out=target --platform=win32 --arch=x64 --asar=true"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^7.2.7",
    "@angular/common": "^7.2.7",
    "@angular/compiler": "^7.2.7",
    "@angular/core": "^7.2.7",
    "@angular/forms": "^7.2.7",
    "@angular/http": "^7.2.7",
    "@angular/platform-browser": "^7.2.7",
    "@angular/platform-browser-dynamic": "^7.2.7",
    "@angular/router": "^7.2.7",
    "bootstrap": "^4.1.3",
    "core-js": "^2.4.1",
    "dateformat": "^3.0.3",
    "jquery": "^3.3.1",
    "minimal-request-promise": "^1.5.0",
    "net": "^1.0.2",
    "popper.js": "^1.14.3",
    "rxjs": "^6.4.0",
    "sockjs-client": "^1.1.5",
    "stompjs": "^2.3.3",
    "tree-kill": "^1.2.0",
    "tslib": "^1.9.0",
    "typescript": "^3.2.4",
    "zone.js": "^0.8.19"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.13.0",
    "@angular/cli": "^7.3.4",
    "@angular/compiler-cli": "^7.2.7",
    "@angular/language-service": "^7.2.7",
    "@types/jasmine": "~2.8.3",
    "@types/jasminewd2": "~2.0.2",
    "@types/node": "~6.0.60",
    "codelyzer": "^4.0.1",
    "electron": "2.0.12",
    "electron-packager": "^12.1.0",
    "ts-node": "~4.1.0",
    "tslint": "~5.9.1",
    "winston": "^3.1.0"
  }
}
