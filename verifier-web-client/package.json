{
  "name": "Verifier",
  "version": "1.0.2",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "ng serve --proxy-config proxy.config.json --base-href /",
    "postinstall": "shx sed -i \"s/module.exports = .*/module.exports = '1.0.28';/g\" node_modules/websocket/lib/version.js && electron-builder install-app-deps",
    "build": "ng lint && ng build --prod",
    "lint": "ng lint",
    "postbuild": "run-script-os",
    "postbuild:darwin:linux": "USE_HARD_LINKS=false BUILD_NUMBER=0 electron-builder build -w --publish=never",
    "postbuild:win32": "electron-builder build -w --publish=never"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^8.2.14",
    "@angular/common": "^8.2.14",
    "@angular/compiler": "^8.2.14",
    "@angular/core": "^8.2.14",
    "@angular/forms": "^8.2.14",
    "@angular/platform-browser": "^8.2.14",
    "@angular/platform-browser-dynamic": "^8.2.14",
    "@angular/router": "^8.2.14",
    "@electron/remote": "1.2.1",
    "@stomp/stompjs": "^6.0.0",
    "bootstrap": "^4.5.3",
    "bootstrap-icons": "^1.3.0",
    "core-js": "^3.8.2",
    "jquery": "^3.5.0",
    "minimal-request-promise": "^1.5.0",
    "net": "^1.0.2",
    "rxjs": "^6.4.0",
    "sockjs-client": "^1.5.0",
    "stompjs": "^2.3.3",
    "tslib": "^1.14.1",
    "typescript": "~3.5.3",
    "zone.js": "^0.9.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^0.803.24",
    "@angular/cli": "^8.2.2",
    "@angular/compiler-cli": "^8.2.14",
    "@angular/language-service": "^8.2.14",
    "@types/jasmine": "~2.8.3",
    "@types/jasminewd2": "~2.0.2",
    "@types/node": "~6.0.60",
    "codelyzer": "^6.0.1",
    "electron": "13.1.8",
    "electron-builder": "22.11.11",
    "electron-reload": "1.5.0",
    "run-script-os": "1.1.6",
    "shx": "^0.3.3",
    "tslint": "~5.9.1"
  }
}
