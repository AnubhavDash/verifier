#!/usr/bin/env groovy
node() {
    timestamps {
        env.PATH = "${tool 'maven-3.3.9'}/bin:${env.PATH}"
        env.JAVA_HOME = "${tool 'jdk-8u131'}"

        WORKSPACE = pwd()

        PROJECT_NAME = 'evoting-verifier'
        SCM_URL = "https://gitit.post.ch/scm/evoting/verifier.git"

        step([$class: 'StashNotifier'])
        currentBuild.result = 'SUCCESS'

        step([$class: 'WsCleanup'])

        sh "wget -O ./common-pipeline.groovy http://artifactory.pnet.ch/artifactory/libs-release-local/ch/post/it/common/jenkins/pipeline/00.02.01.00/pipeline-00.02.01.00.jar!jenkins-build-pipeline.groovy"
		def commonPipeline = load 'common-pipeline.groovy'

        //NAE: Problem with lombok while compiling. Java should have more Xss memory. Modifying RTMAVEN object defined from common-pipeline
        RTMAVEN.opts = "-Xss1024m ${RTMAVEN.opts}"

        commonPipeline.checkoutSource(SCM_URL, BRANCH_NAME)
        commonPipeline.buildMaven(PROJECT_NAME, "clean install", "-Pdoc", BRANCH_NAME, true)

        step([$class: 'CucumberReportPublisher', jsonReportDirectory: "target", fileIncludePattern: '**/*cucumber*.json'])

        cleanWs deleteDirs: true, patterns: [[pattern: '**/archive-tmp/**', type: 'INCLUDE']]

        commonPipeline.saveArtifacts(PROJECT_NAME, 'snapshot', BRANCH_NAME)
        commonPipeline.sendEmail(PROJECT_NAME, BRANCH_NAME, "jenkinsapps", "Please check the latest build and fix the error.", false, 'nils.aellen@post.ch', true)
        step([$class: 'StashNotifier'])
    }
}