@Library(['pipeline-library@master', 'evoting-pipeline@master']) _

def BUILD_INFO = Artifactory.newBuildInfo()
def PROJECT_NAME = 'verifier'
def SCM_URL = "https://gitit.post.ch/scm/evotingecosystem/verifier.git"
def SCM_URL_ANON = "https://gitit.post.ch/scm/evotinganonymized/verifier.git"

pipeline {

	agent {
		label 'apps-slaves-evoting'
	}

	options {
		disableConcurrentBuilds()
		buildDiscarder(logRotator(numToKeepStr: '10'))
		ansiColor('xterm')
		timestamps()
	}

	stages {

		stage('Prepare') {
			steps {
				step([$class: 'StashNotifier'])
				cleanWs()
				clone(
						branch: "develop",
						url: SCM_URL,
						credentialsId: "s-cicd-evoting")
			}
		}

		stage('Anonymize') {
			steps {
				anonymization(
						gitAnonymousUserName: "SwissPost-Bot",
						gitAnonymousUserEmail: "evotingspoc@poste.ch",
						fileToRemove: "Jenkinsfile,JenkinsfileRelease,JenkinsfileAnonymizeDevelop, JenkinsfileFortify,jenkins-release-verifier.groovy,.mvn,ide/");
			}
		}

		stage('push target branch') {
			steps {
				forcePush(
						branch: 'pre-publication-develop',
						url: SCM_URL_ANON,
						credentialsId: "s-cicd-evoting");
			}
		}

	}

	post {
		always {
			step([$class: 'StashNotifier'])
		}
		failure {
			sendBuildMail(projectName: PROJECT_NAME, message: 'Hi, the verifier develop anonymization build has failed', onError: true, toCommitters: true)
		}
	}
}