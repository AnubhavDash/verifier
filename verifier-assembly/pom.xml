<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
				 xmlns="http://maven.apache.org/POM/4.0.0"
				 xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<artifactId>verifier</artifactId>
		<groupId>ch.post.it.evoting.verifier</groupId>
		<version>1.0.2.1-SNAPSHOT</version>
	</parent>

	<artifactId>verifier-assembly</artifactId>
	<packaging>pom</packaging>

	<properties>
		<adoptopenjdk.url>https://artifactory.tools.pnet.ch/artifactory/files-local/adoptopenjdk/OpenJDK11U-jdk_x64_windows_hotspot_11.0.9.1_1.zip
		</adoptopenjdk.url>
		<adoptopenjdk.sha256>fea633dc37f007cb6b1e1af1874da63ad3d5e31817e583048287c67010dce5c8</adoptopenjdk.sha256>
		<download-maven-plugin.version>1.6.0</download-maven-plugin.version>
	</properties>

	<profiles>
		<profile>
			<id>electron-package</id>
			<dependencies>
				<dependency>
					<groupId>ch.post.it.evoting.verifier</groupId>
					<artifactId>verifier-web-client</artifactId>
					<type>zip</type>
				</dependency>
				<dependency>
					<groupId>ch.post.it.evoting.verifier</groupId>
					<artifactId>verifier-web</artifactId>
				</dependency>
			</dependencies>
			<build>
				<plugins>
					<plugin>
						<groupId>com.googlecode.maven-download-plugin</groupId>
						<artifactId>download-maven-plugin</artifactId>
						<version>${download-maven-plugin.version}</version>
						<executions>
							<execution>
								<id>install-openjdk</id>
								<phase>generate-resources</phase>
								<goals>
									<goal>wget</goal>
								</goals>
								<configuration>
									<url>${adoptopenjdk.url}</url>
									<unpack>true</unpack>
									<outputDirectory>${project.build.directory}/jdk</outputDirectory>
									<sha256>${adoptopenjdk.sha256}</sha256>
								</configuration>
							</execution>
						</executions>
					</plugin>
					<plugin>
						<groupId>org.apache.maven.plugins</groupId>
						<artifactId>maven-assembly-plugin</artifactId>
						<executions>
							<execution>
								<id>distro-assembly</id>
								<phase>package</phase>
								<goals>
									<goal>single</goal>
								</goals>
								<configuration>
									<descriptors>
										<descriptor>src/main/assembly/assembly.xml</descriptor>
									</descriptors>
								</configuration>
							</execution>
						</executions>
					</plugin>
				</plugins>
			</build>
		</profile>
	</profiles>
</project>
