<assembly xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
					xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3"
					xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3 http://maven.apache.org/xsd/assembly-1.1.3.xsd">
	<id>verifier-assembly</id>
	<formats>
		<format>zip</format>
	</formats>
	<includeBaseDirectory>false</includeBaseDirectory>

	<dependencySets>
		<!-- Verifier frontend archive -->
		<!-- Electron executable & Angular UI -->
		<dependencySet>
			<includes>
				<include>${project.groupId}:${rootProject}-frontend</include>
			</includes>
			<fileMode>0644</fileMode>
			<directoryMode>0755</directoryMode>
			<outputDirectory/>
			<unpack>true</unpack>
			<useProjectArtifact>false</useProjectArtifact>
		</dependencySet>
		<!-- Verifier backend archive -->
		<!-- jar executable -->
		<dependencySet>
			<includes>
				<include>${project.groupId}:${rootProject}-backend</include>
			</includes>
			<fileMode>0644</fileMode>
			<directoryMode>0755</directoryMode>
			<outputDirectory>./resources</outputDirectory>
			<outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
			<useProjectArtifact>false</useProjectArtifact>
		</dependencySet>
	</dependencySets>
	<!-- JRE & bat executable -->
	<fileSets>
		<fileSet>
			<fileMode>0644</fileMode>
			<directoryMode>0755</directoryMode>
			<directory>${project.build.directory}/jre</directory>
			<outputDirectory>./resources</outputDirectory>
		</fileSet>
		<fileSet>
			<fileMode>0644</fileMode>
			<directoryMode>0755</directoryMode>
			<directory>${project.basedir}/src/main/resources</directory>
			<outputDirectory>./resources</outputDirectory>
			<filtered>true</filtered>
			<includes>
				<include>run-backend.bat</include>
				<include>application.yaml</include>
			</includes>
		</fileSet>
		<fileSet>
			<fileMode>0644</fileMode>
			<directoryMode>0755</directoryMode>
			<directory>${project.basedir}/..</directory>
			<outputDirectory/>
			<includes>
				<include>README.md</include>
			</includes>
		</fileSet>
	</fileSets>

</assembly>
