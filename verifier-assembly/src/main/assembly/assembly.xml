<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
					xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3"
					xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3 http://maven.apache.org/xsd/assembly-1.1.3.xsd">
	<id>verifier-assembly</id>
	<formats>
		<format>zip</format>
	</formats>
	<includeBaseDirectory>false</includeBaseDirectory>

	<dependencySets>
		<dependencySet>
			<outputDirectory/>
			<includes>
				<include>${project.groupId}:${rootProject}-web-client</include>
			</includes>
			<unpack>true</unpack>
			<useProjectArtifact>false</useProjectArtifact>
		</dependencySet>
		<dependencySet>
			<outputDirectory>./resources</outputDirectory>
			<includes>
				<include>${project.groupId}:${rootProject}-web</include>
			</includes>
			<outputFileNameMapping>${artifact.artifactId}.${artifact.extension}</outputFileNameMapping>
			<useProjectArtifact>false</useProjectArtifact>
		</dependencySet>
	</dependencySets>

	<fileSets>
		<fileSet>
			<directory>${project.build.directory}/jdk</directory>
			<outputDirectory>./resources</outputDirectory>
			<filtered>false</filtered>
		</fileSet>
	</fileSets>
	<files>
		<file>
			<source>${project.basedir}/src/main/resources/run-backend.bat</source>
			<outputDirectory>./resources</outputDirectory>
			<filtered>true</filtered>
		</file>
	</files>
</assembly>
