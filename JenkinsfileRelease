@Library(['pipeline-library@master', 'evoting-pipeline@master']) _

def BUILD_INFO = Artifactory.newBuildInfo()
def PROJECT_NAME = 'verifier'
def SCM_URL = "https://gitit.post.ch/scm/evotingecosystem/verifier.git"
def SCM_URL_ANON = "https://gitit.post.ch/scm/evotinganonymized/verifier.git"

ARTIFACTORY_SERVER = Artifactory.server 'artifactory'
RTMAVEN = Artifactory.newMavenBuild()
RTMAVEN.deployer releaseRepo: 'libs-release-evoting-local', snapshotRepo: 'libs-snapshot-evoting-local', server: ARTIFACTORY_SERVER
RTMAVEN.resolver releaseRepo: 'swisspost', snapshotRepo: 'swisspost', server: ARTIFACTORY_SERVER

// Tools
def JDK = 'jdk-17.0.3'
def NODEJS = 'node-v14.17.0'
def MAVEN = 'maven-3.8.6'

pipeline {

	agent {
		label 'apps-slaves-evoting'
	}

	parameters {
		string(name: 'BRANCH_NAME', defaultValue: 'release/verifier-x.x.x.x', description: 'GIT branch where the release is starting. Default is "release/verifier-x.x.x.x".')
		string(name: 'RELEASE_VERSION', defaultValue: 'x.x.x.x', description: 'Set to the desired version to be released. Usually the Bugfix-Version number is bumped from the last RELEASE_VERSION eg 1.1.3.0 -> 1.1.4.0 You can get the last (tagged) RELEASE_VERSION with this cmd: git describe --abbrev=0 If you enter the value of an existing version, the Job will fail (due to duplicated tags)')
		string(name: 'NEW_SNAPSHOT_VERSION', defaultValue: 'x.x.x.x-SNAPSHOT', description: 'Set to a version higher than RELEASE_VERSION and add the suffix -SNAPSHOT eg. 1.2.0.0-SNAPSHOT')
		string(name: 'RELEASE_MESSAGE', defaultValue: 'merge release verifier x.x.x.x', description: 'Set the release commit message')
		booleanParam(name: 'AUTO_MERGE', defaultValue: true, description: 'Auto merge given branch into master.')
	}

	options {
		disableConcurrentBuilds()
		buildDiscarder(logRotator(numToKeepStr: '10'))
		ansiColor('xterm')
		timestamps()
	}

	tools {
		jdk "${JDK}"
		maven "${MAVEN}"
	}

	environment {
		MAVEN_OPTS = '-Xms512m -Xmx768m -Djava.awt.headless=true'
		//workaround for https://gitit.post.ch/projects/JENKINS/repos/jenkins-slave-selenium/browse/Dockerfile#15
	}

	stages {

		stage('Informations') {
			steps {

				script {
					currentBuild.displayName = "#${BUILD_INFO.number} ${RELEASE_VERSION} :: ${NEW_SNAPSHOT_VERSION}"
					currentBuild.description = "Jenkins job to release the verifier"
				}

				echo "--------------------------------- Build Information : ---------------------------------"
				echo ""
				echo "Build information :"
				echo "${BUILD_INFO}";
				echo "Build name :"
				echo "${BUILD_INFO.name}";
				echo "Build number :"
				echo "${BUILD_INFO.number}";
				echo "Build starting date :"
				echo "${BUILD_INFO.startDate}";
				echo "Maven version :"
				sh "mvn -v"
				echo "Java version :"
				sh "java -version"
				echo "Nodejs version :"
				sh "node -v"
				echo ""
				echo "---------------------------------------------------------------------------------------"
			}
		}

		stage('Prepare') {
			steps {
				cleanWs()
				checkout scm
			}
		}

		stage('Release') {
			steps {
				script {
					def verifierReleasePipelineLib = load 'jenkins-release-verifier.groovy'

					withEnv(["EVOTING_HOME=${env.WORKSPACE}"]) {
						verifierReleasePipelineLib.performRelease(PROJECT_NAME, SCM_URL, BRANCH_NAME, AUTO_MERGE, 'clean deploy', '-Pdoc -DskipTests -settings ${EVOTING_HOME}/.mvn/settings.xml', WORKSPACE, RELEASE_VERSION, NEW_SNAPSHOT_VERSION, "spoc-dev-evoting@post.ch", false, PROJECT_NAME, RELEASE_MESSAGE)
					}
				}
			}
		}

		stage('Anonymize') {
			steps {
				sh "git checkout master"
				anonymization(
						gitAnonymousUserName: "SwissPost-Bot",
						gitAnonymousUserEmail: "evotingspoc@poste.ch",
						fileToRemove: "Jenkinsfile,JenkinsfileRelease,JenkinsfileAnonymizeDevelop, JenkinsfileFortify,jenkins-release-verifier.groovy,.mvn,ide/");
			}
		}

	}

	post {
		cleanup {
			step([$class: 'StashNotifier'])
		}
		always {
			step([$class: 'StashNotifier'])
		}
		failure {
			sendBuildMail(projectName: PROJECT_NAME, message: 'Hi, the verifier RELEASE build has failed!!', onError: true, toCommitters: true)
		}
	}
}
