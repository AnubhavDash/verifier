{
  "asar": false,
  "buildVersion": "1",
  "copyright": "(c) Copyright 2024 Swiss Post Ltd.",
  "directories": {
    "output": "target/electron"
  },
  "files": [
    "**/*",
    "!**/*.ts",
    "!*.map",
    "!package.json",
    "!package-lock.json"
  ],
  "extraResources": [
    {
      "from": "dist",
      "to": "app",
      "filter": [
        "**/*"
      ]
    }
  ],
  "win": {
    "target": [{"target": "dir", "arch": ["x64"]}]
  }
}
