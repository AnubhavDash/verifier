    "@angular/platform-browser-dynamic": "^14.1.1",
    "@angular/router": "^14.1.1",
    "@electron/remote": "2.0.8",
    "@stomp/stompjs": "^6.1.2",
    "bootstrap": "^4.6.2",
    "bootstrap-icons": "^1.9.1",
    "core-js": "^3.24.1",
    "html2pdf.js": "^0.10.1",
    "jquery": "^3.6.0",
    "minimal-request-promise": "^1.5.0",
