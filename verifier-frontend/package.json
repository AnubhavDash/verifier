{
  "name": "Verifier",
  "version": "1.6.0-0-SNAPSHOT",
  "description": "Swiss Post Verifier",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "ng serve --proxy-config proxy.config.json",
    "build": "ng build --configuration production",
    "lint": "ng lint",
    "postbuild": "cd app/ && npm ci && cd .. && run-script-os",
    "postbuild:darwin:linux": "USE_HARD_LINKS=false BUILD_NUMBER=0 electron-builder build -w --publish=never",
    "postbuild:win32": "electron-builder build -w --publish=never"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "19.2.6",
    "@angular/common": "19.2.6",
    "@angular/compiler": "19.2.6",
    "@angular/core": "19.2.6",
    "@angular/forms": "19.2.6",
    "@angular/platform-browser": "19.2.6",
    "@angular/platform-browser-dynamic": "19.2.6",
    "@angular/router": "19.2.6",
    "@ng-bootstrap/ng-bootstrap": "18.0.0",
    "@ngx-translate/core": "16.0.4",
    "@ngx-translate/http-loader": "16.0.1",
    "@stomp/stompjs": "7.1.1",
    "bootstrap": "5.3.5",
    "bootstrap-icons": "1.11.3",
    "core-js": "3.41.0",
    "e-voting-libraries-ui-kit": "file:vendor/e-voting-libraries-ui-kit",
    "html2pdf.js": "0.10.3",
    "jspdf": "3.0.1",
    "minimal-request-promise": "1.5.0",
    "net": "1.0.2",
    "rxjs": "7.8.2",
    "sockjs-client": "1.6.1",
    "stompjs": "2.3.3",
    "zone.js": "0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "19.2.7",
    "@angular-eslint/builder": "19.3.0",
    "@angular-eslint/eslint-plugin": "19.3.0",
    "@angular/cli": "19.2.7",
    "@angular/compiler-cli": "19.2.6",
    "@angular/language-service": "19.2.6",
    "@types/jasmine": "5.1.7",
    "@types/jasminewd2": "2.0.13",
    "@types/node": "22.14.0",
    "@typescript-eslint/eslint-plugin": "8.29.1",
    "@typescript-eslint/parser": "8.29.1",
    "electron": "35.1.4",
    "electron-builder": "26.0.12",
    "electron-reload": "2.0.0-alpha.1",
    "eslint": "9.24.0",
    "run-script-os": "1.1.6",
    "tslib": "2.8.1",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=14",
    "npm": ">=6"
  },
  "overrides": {
    "websocket": "1.0.35"
  },
  "builders": "builders.json"
}
