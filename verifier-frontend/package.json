{
  "name": "Verifier",
  "version": "1.5.5-1",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "ng serve --proxy-config proxy.config.json",
    "build": "ng lint && ng build --configuration production",
    "lint": "ng lint",
    "postbuild": "cd app/ && npm ci && cd .. && run-script-os",
    "postbuild:darwin:linux": "USE_HARD_LINKS=false BUILD_NUMBER=0 electron-builder build -w --publish=never",
    "postbuild:win32": "electron-builder build -w --publish=never"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "17.3.12",
    "@angular/common": "17.3.12",
    "@angular/compiler": "17.3.12",
    "@angular/core": "17.3.12",
    "@angular/forms": "17.3.12",
    "@angular/platform-browser": "17.3.12",
    "@angular/platform-browser-dynamic": "17.3.12",
    "@angular/router": "17.3.12",
    "@stomp/stompjs": "7.1.1",
    "bootstrap": "5.3.6",
    "bootstrap-icons": "1.13.1",
    "core-js": "3.42.0",
    "html2pdf.js": "0.10.3",
    "jquery": "3.7.1",
    "minimal-request-promise": "1.5.0",
    "net": "1.0.2",
    "@popperjs/core": "2.11.8",
    "rxjs": "7.8.2",
    "sockjs-client": "1.6.1",
    "stompjs": "2.3.3",
    "zone.js": "0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "17.3.17",
    "@angular-eslint/builder": "18.4.3",
    "@angular-eslint/eslint-plugin": "18.4.3",
    "@angular/cli": "17.3.17",
    "@angular/compiler-cli": "17.3.12",
    "@angular/language-service": "17.3.12",
    "@types/jasmine": "5.1.8",
    "@types/jasminewd2": "2.0.13",
    "@types/node": "20.17.46",
    "@typescript-eslint/eslint-plugin": "8.32.0",
    "@typescript-eslint/parser": "8.32.0",
    "electron": "28.3.3",
    "electron-builder": "24.13.3",
    "electron-reload": "2.0.0-alpha.1",
    "eslint": "9.26.0",
    "run-script-os": "1.1.6",
    "shx": "0.4.0",
    "tslib": "2.8.1",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=14",
    "npm": ">=6"
  },
  "//": "Websocket is overridden because its version is referenced as 'latest' that breaks the reproducibility",
  "overrides": {
    "websocket": "1.0.35"
  }
}
