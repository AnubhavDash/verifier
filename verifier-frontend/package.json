    "@angular/router": "^15.2.6",
    "@electron/remote": "2.0.9",
    "@stomp/stompjs": "^6.1.2",
    "bootstrap": "^4.6.2",
    "bootstrap-icons": "^1.10.4",
    "core-js": "^3.30.0",
