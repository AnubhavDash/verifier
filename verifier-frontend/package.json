{
  "name": "Verifier",
  "version": "1.5.0-0-SNAPSHOT",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "ng serve --proxy-config proxy.config.json",
    "build": "ng lint && ng build --configuration production",
    "lint": "ng lint",
    "postbuild": "cd app/ && npm ci && cd .. && run-script-os",
    "postbuild:darwin:linux": "USE_HARD_LINKS=false BUILD_NUMBER=0 electron-builder build -w --publish=never",
    "postbuild:win32": "electron-builder build -w --publish=never"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "15.2.10",
    "@angular/common": "15.2.10",
    "@angular/compiler": "15.2.10",
    "@angular/core": "15.2.10",
    "@angular/forms": "15.2.10",
    "@angular/platform-browser": "15.2.10",
    "@angular/platform-browser-dynamic": "15.2.10",
    "@angular/router": "15.2.10",
    "@stomp/stompjs": "6.1.2",
    "bootstrap": "4.6.2",
    "bootstrap-icons": "1.11.3",
    "core-js": "3.35.0",
    "html2pdf.js": "0.10.1",
    "minimal-request-promise": "1.5.0",
    "net": "1.0.2",
    "@popperjs/core": "2.11.8",
    "rxjs": "7.8.1",
    "sockjs-client": "1.6.1",
    "stompjs": "2.3.3",
    "zone.js": "0.13.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "15.2.10",
    "@angular-eslint/builder": "15.2.1",
    "@angular-eslint/eslint-plugin": "15.2.1",
    "@angular/cli": "15.2.10",
    "@angular/compiler-cli": "15.2.10",
    "@angular/language-service": "15.2.10",
    "@types/jasmine": "4.6.4",
    "@types/jasminewd2": "2.0.13",
    "@types/node": "18.19.6",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "electron": "24.3.1",
    "electron-builder": "23.6.0",
    "electron-reload": "2.0.0-alpha.1",
    "eslint": "8.56.0",
    "eslint-plugin-import": "2.29.1",
    "run-script-os": "1.1.6",
    "shx": "0.3.4",
    "tslib": "2.6.2",
    "typescript": "4.9.5"
  },
  "overrides": {
    "commander": "3.0.2",
    "minimatch": "3.1.2"
  },
  "engines": {
    "node": ">=14",
    "npm": ">=6"
  }
}
