{
  "name": "Verifier",
  "version": "1.4.1-0-SNAPSHOT",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "ng serve --proxy-config proxy.config.json",
    "build": "ng lint && ng build --configuration production",
    "lint": "ng lint",
    "postbuild": "npm ci app/ && run-script-os",
    "postbuild:darwin:linux": "USE_HARD_LINKS=false BUILD_NUMBER=0 electron-builder build -w --publish=never",
    "postbuild:win32": "electron-builder build -w --publish=never"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "15.2.9",
    "@angular/common": "15.2.9",
    "@angular/compiler": "15.2.9",
    "@angular/core": "15.2.9",
    "@angular/forms": "15.2.9",
    "@angular/platform-browser": "15.2.9",
    "@angular/platform-browser-dynamic": "15.2.9",
    "@angular/router": "15.2.9",
    "@stomp/stompjs": "6.1.2",
    "bootstrap": "4.6.2",
    "bootstrap-icons": "1.10.5",
    "core-js": "3.31.0",
    "html2pdf.js": "0.10.1",
    "minimal-request-promise": "1.5.0",
    "net": "1.0.2",
    "@popperjs/core": "2.11.8",
    "rxjs": "7.8.1",
    "sockjs-client": "1.6.1",
    "stompjs": "2.3.3",
    "zone.js": "0.13.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "15.2.8",
    "@angular-eslint/builder": "15.2.1",
    "@angular-eslint/eslint-plugin": "15.2.1",
    "@angular/cli": "15.2.8",
    "@angular/compiler-cli": "15.2.9",
    "@angular/language-service": "15.2.9",
    "@types/jasmine": "4.3.2",
    "@types/jasminewd2": "2.0.10",
    "@types/node": "18.16.18",
    "@typescript-eslint/eslint-plugin": "5.59.11",
    "@typescript-eslint/parser": "5.59.11",
    "electron": "24.3.1",
    "electron-builder": "23.6.0",
    "electron-reload": "2.0.0-alpha.1",
    "eslint": "8.42.0",
    "eslint-plugin-import": "2.27.5",
    "run-script-os": "1.1.6",
    "shx": "0.3.4",
    "tslib": "2.5.3",
    "typescript": "4.9.5"
