    "@angular/platform-browser-dynamic": "^15.2.9",
    "@angular/router": "^15.2.9",
    "@electron/remote": "2.0.9",
    "@stomp/stompjs": "^6.1.2",
    "bootstrap": "^4.6.2",
    "bootstrap-icons": "^1.10.5",
    "core-js": "^3.30.2",
    "html2pdf.js": "^0.10.1",
    "jquery": "^3.7.0",
    "minimal-request-promise": "^1.5.0",
    "net": "^1.0.2",
    "@popperjs/core": "^2.11.7",
    "rxjs": "^7.8.1",
