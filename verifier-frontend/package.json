    "@angular/language-service": "^15.2.9",
    "@types/jasmine": "~4.3.1",
    "@types/jasminewd2": "~2.0.10",
    "@types/node": "^18.16.14",
    "@typescript-eslint/eslint-plugin": "^5.59.7",
    "@typescript-eslint/eslint-plugin-tslint": "^5.59.7",
    "@typescript-eslint/parser": "^5.59.7",
    "codelyzer": "^6.0.2",
    "electron": "24.3.1",
